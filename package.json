{
  "name": "digital-wardrobe-backend",
  "version": "1.0.0",
  "description": "Backend service for the Digital Wardrobe web app using Express, Sequelize, and AWS SDK (Cognito Auth)",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "db:migrate": "sequelize db:migrate",
    "db:seed": "sequelize db:seed:all",
    "db:create": "sequelize db:create",
    "lint": "eslint .",
    "test": "jest --runInBand"
  },
  "directories": {
    "test": "tests"
  },
  "keywords": [
    "digital-wardrobe",
    "aws-cognito",
    "sequelize",
    "express",
    "backend"
  ],
  "author": "Aishat",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "aws-jwt-verify": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^9.36.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "sequelize-cli": "^6.6.3",
    "supertest": "^7.1.4"
  }
}
